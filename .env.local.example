# Archana Sweets - Environment Variables
# Copy this file to .env.local for the Next.js app.
# Copy or adapt the backend values into backend/.env if you run FastAPI separately.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Archana Sweets
NEXT_PUBLIC_APP_TAGLINE=Made With Mother's Love
NEXT_PUBLIC_SITE_URL=https://www.archanasweets.com
NEXT_PUBLIC_SITE_NAME=Archana Sweets
NEXT_PUBLIC_CURRENCY=INR

# FastAPI Backend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
APP_NAME=Archana Sweets API
API_VERSION=1.0.0
API_PREFIX=/api/v1

DEBUG=true
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://archanasweets.com,https://www.archanasweets.com

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/archanasweets_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=300
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JWT / Auth
JWT_SECRET_KEY=change-this-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=

# Stripe - future international checkout
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Media Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=archanasweets-media
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Search
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# SMS / OTP
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-otp-template-id
NEXT_PUBLIC_OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=no-reply@archanasweets.com
EMAIL_FROM=orders@archanasweets.com

# Analytics / Monitoring
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# WhatsApp Business
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Admin
ADMIN_EMAILS=admin@archanasweets.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
